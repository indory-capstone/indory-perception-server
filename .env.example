# control-server-detection example configuration.
# Copy to .env for local use. Do not commit real .env files.

CONTROL_SERVER_DETECTION_HOST=127.0.0.1
CONTROL_SERVER_DETECTION_PORT=8767
CONTROL_SERVER_DETECTION_PROVIDER=gz_compat
CONTROL_SERVER_DETECTION_KEEP_ARTIFACTS=0
CONTROL_SERVER_DETECTION_INCLUDE_DEBUG=0
CONTROL_SERVER_DETECTION_MAX_IMAGE_MB=16

# Optional local runtime paths. Use machine-specific paths only in your private .env.
INDORY_OCR_BASE_PYTHON=python3
INDORY_OCR_SETUP=
WAYBILL_OCR_ROOT=

# Waybill LLM judge. Keep model weights outside git.
WAYBILL_OCR_JUDGE_MODE=llama_cpp
WAYBILL_OCR_DEFAULT_MODEL=
WAYBILL_OCR_MODEL=
WAYBILL_OCR_ENDPOINT=
WAYBILL_LLM_CTX=4096
WAYBILL_LLM_MAX_NEW_TOKENS=128
WAYBILL_OCR_REQUIRE_PADDLE=1
